# =============================================================================
# WorldCalib secrets — fill in and save as `.env` (gitignored).
# =============================================================================
#
# Copy template:
#     cp .env.example .env && $EDITOR .env
#
# Launch scripts source `.env` automatically. NEVER commit the real `.env`.
# =============================================================================

# --- Proposer (Claude Kimi K2.6 via docker-claude-kimi) ----------------------
# Get from https://platform.moonshot.cn/console/api-keys
# If the key starts with "sk-kimi-" the launcher routes to api.kimi.com/coding,
# otherwise it falls back to api.moonshot.ai/anthropic.
KIMI_API_KEY=sk-kimi-XXXXXXXXXXXXXXXXXXXX

# Optional overrides; defaults in launch_wmc_default_nosummary.sh:
#   KIMI_BASE_URL=https://api.kimi.com/coding
#   KIMI_MODEL=kimi-k2.6

# --- Target model (DeepSeek v4 Flash) ----------------------------------------
# Get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX

# --- Embeddings (OpenAI text-embedding-3-small, used by trace_similar) -------
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
